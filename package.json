{
    "name": "pre-sales-ai-advisor",
    "version": "1.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --host 127.0.0.1 --port 5174 --strictPort",
        "dev:calibration": "vite --host 127.0.0.1 --port 5175 --strictPort",
        "dev:reverb-calibration": "vite --host 127.0.0.1 --port 5176 --strictPort",
        "dev:wiring-calibration": "npm.cmd run dev:reverb-calibration",
        "dev:yinman": "vite --host 127.0.0.1 --port 5180 --strictPort",
        "dev:selection-calibration": "npm.cmd run dev:wiring-calibration",
        "build": "tsc && vite build",
        "audit:product-docs": "node scripts/audit-product-docs.mjs",
        "test:point-system": "node scripts/verify-point-system-rules.mjs",
        "test:product-doc-audit": "node scripts/verify-product-doc-audit.mjs",
        "test:reverberation": "node scripts/verify-reverberation-rules.mjs",
        "preview": "vite preview --host 127.0.0.1",
        "generate:random-presales": "node scripts/generateRandomPresales.mjs",
        "release:yinyi": "npm.cmd run build && node scripts/build-single-file-release.mjs --brand yinyi && node scripts/build-universal-release.mjs --brand yinyi",
        "release:universal": "npm.cmd run release:yinyi",
        "release:yinman": "npm.cmd run build && node scripts/build-single-file-release.mjs --brand yinman && node scripts/build-universal-release.mjs --brand yinman",
        "release:all": "npm.cmd run release:yinyi && npm.cmd run release:yinman && npm.cmd run verify:release-current && npm.cmd run verify:release-behavior",
        "verify:release-current": "node scripts/verify-release-current.mjs",
        "verify:release-behavior": "node scripts/verify-release-behavior-parity.mjs",
        "test:release-mobile": "node scripts/test-release-mobile-compat.mjs",
        "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^5.0.0",
        "lucide-react": "^0.468.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "typescript": "^5.9.0",
        "vite": "^7.1.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "playwright": "^1.61.1"
    }
}
